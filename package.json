{
  "name": "expensit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "start-dev": "vite --mode apidev",
    "build": "rm -rf dist && run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --project tsconfig.app.json",
    "lint:oxlint": "oxlint . -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint .",
    "lint": "run-s lint:*",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui --watch"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@tailwindcss/vite": "^4.2.2",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.14.0",
    "date-fns": "^4.1.0",
    "destr": "^2.0.5",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "portal-vue": "^3.0.0",
    "ua-parser-js": "^2.0.9",
    "vite-svg-loader": "^5.1.1",
    "vue": "^3.5.31",
    "vue-multiselect": "^3.5.0",
    "vue-router": "^5.0.4",
    "vue-toast-notification": "^3.1.3",
    "vue3-popper": "^1.5.0"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@prettier/plugin-oxc": "^0.1.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/ui": "^4.1.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.37.0",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "prettier": "3.8.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.1.9",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6",
    "workbox-window": "^7.4.0"
  }
}
